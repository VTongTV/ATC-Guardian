# ============================================================================
# ATC Guardian — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# Get API keys from:
#   - OpenRouter:  https://openrouter.ai (free, no credit card)
#   - Band:        https://app.band.ai/agents (register 5 remote agents)
#   - OpenSky:     https://opensky-network.org (free account)
#   - AI/ML API:   https://aimlapi.com (hackathon partner promo code)
# ============================================================================

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
DEBUG=false
DEFAULT_SCENARIO_ID=SCN-A
SIMULATION_INTERVAL_SECONDS=4.0
CORS_ORIGIN=http://localhost:5173

# ----------------------------------------------------------------------------
# LLM Provider — which provider to use for agent LLM calls
# ----------------------------------------------------------------------------
# Options: openrouter | aimlapi
# - openrouter:  Free models, use for development/testing (DEFAULT)
# - aimlapi:     Hackathon partner credits, use for demo/judging.
#                Set LLM_PROVIDER=aimlapi to route every agent through the
#                "one API, many labs, right model per job" partner config
#                documented in the Per-Agent Model Overrides below.
LLM_PROVIDER=openrouter

# ----------------------------------------------------------------------------
# OpenRouter — https://openrouter.ai (free signup, no credit card)
# ----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Free model options (all support tool calling, 20 RPM / 200 RPD per model):
#   meta-llama/llama-3.3-70b-instruct:free     — general-purpose, 128K (default)
#   nvidia/nemotron-3-ultra-550b-a55b:free      — reasoning, 1M context
#   qwen/qwen3-coder:free                       — coding, 1M context
#   openai/gpt-oss-120b:free                    — OpenAI open-weight, 128K
#   openai/gpt-oss-20b:free                     — lightweight, 128K
#   google/gemma-4-31b-it:free                  — multimodal, 256K
#   openrouter/free                             — auto-selects best free model

# ----------------------------------------------------------------------------
# AI/ML API — https://aimlapi.com (hackathon partner promo code)
# ----------------------------------------------------------------------------
# One API key unlocks every lab below. The per-agent assignments in the next
# section route each agent to the model best matched to its task — the pitch
# for the Best Use of AI/ML API prize.
AIMLAPI_KEY=
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
# Default model — used when an agent has no per-agent *_MODEL override.
# DeepSeek V4 Pro: strong analytical reasoning + reliable structured JSON
# output, the safest single fallback. Per-agent overrides below swap in
# GPT-5.1, GLM-5.1, Kimi K2-6, etc. where each fits best.
AIMLAPI_DEFAULT_MODEL=deepseek/deepseek-v4-pro
# Curated model pool available through AI/ML API:
#   deepseek/deepseek-v4-pro     — strong structured-output reasoning (DEFAULT)
#   deepseek/deepseek-v4-flash   — fast DeepSeek variant (ground-ops tool calls)
#   openai/gpt-5-1-chat-latest   — GPT-5.1, configurable reasoning depth
#   openai/gpt-5-1               — reasoning variant (high reasoning effort)
#   google/gemini-3.5-flash      — low-latency, tool-call heavy
#   zhipu/glm-5.1                — adversarial review / safety-critical
#   moonshot/kimi-k2-6           — long-context coordination

# ----------------------------------------------------------------------------
# Per-Agent Model Overrides (optional — falls back to provider default)
# ----------------------------------------------------------------------------
# Uncomment and set to use a different model for a specific agent.
#
# CONFIRMED PARTNER ROUTING (for the Best Use of AI/ML API prize):
# Set LLM_PROVIDER=aimlapi and uncomment the block below so each agent uses
# the model tuned to its task. This exact mapping is enforced in
# shared/partner_routing.py (PARTNER_MODEL_ASSIGNMENTS).
#
#   conflict-detector  -> deepseek/deepseek-v4-pro    (structured-output reasoning)
#   safety-reviewer    -> zhipu/glm-5.1               (adversarial review)
#   weather-analyst    -> deepseek/deepseek-v4-pro    (structured-output reasoning)
#   coordinator        -> moonshot/kimi-k2-6          (long-context coordination)
#   emergency-response -> zhipu/glm-5.1               (safety-critical)
#   ground-ops         -> deepseek/deepseek-v4-flash  (fast tool calls)
#
# CONFLICT_DETECTOR_MODEL=deepseek/deepseek-v4-pro
# SAFETY_REVIEWER_MODEL=zhipu/glm-5.1
# WEATHER_ANALYST_MODEL=deepseek/deepseek-v4-pro
# COORDINATOR_MODEL=moonshot/kimi-k2-6
# EMERGENCY_RESPONSE_MODEL=zhipu/glm-5.1
# GROUND_OPS_MODEL=deepseek/deepseek-v4-flash
#
# OpenRouter fallbacks (free models, set LLM_PROVIDER=openrouter):
#   COORDINATOR_MODEL=meta-llama/llama-3.3-70b-instruct:free
#   CONFLICT_DETECTOR_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
#   WEATHER_ANALYST_MODEL=meta-llama/llama-3.3-70b-instruct:free
#   GROUND_OPS_MODEL=meta-llama/llama-3.3-70b-instruct:free
#   EMERGENCY_RESPONSE_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
#   SAFETY_REVIEWER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ----------------------------------------------------------------------------
# Band Platform — https://app.band.ai/agents
# ----------------------------------------------------------------------------
# 1. Create account at https://band.ai
# 2. Go to https://app.band.ai/agents
# 3. Click "New Agent" → "Remote Agent" for each of the 5 agents below
# 4. Copy the Agent UUID and API Key for each
# 5. Create a chat room at https://app.band.ai and add all 5 agents as participants
# 6. Copy the room ID below
#
# NOTE: API keys are shown ONCE at creation. Save them immediately!
#
# BAND_MODE controls how the backend talks to agents:
#   sim  — offline in-process simulation (DEFAULT; no Band account needed,
#          the full detect → @mention → advisory loop runs locally)
#   live — real Band REST calls (requires BAND_API_KEY + BAND_ROOM_ID and
#          all 6 agent processes running against Band)
BAND_MODE=sim

# Band room where all agents communicate (only required when BAND_MODE=live)
BAND_API_KEY=band_u_your-band-api-key-here
BAND_ROOM_ID=00000000-0000-0000-0000-000000000000

# Coordinator Agent (LangGraph)
COORDINATOR_AGENT_ID=00000000-0000-0000-0000-000000000001
COORDINATOR_API_KEY=band_u_coordinator-key-here

# Conflict Detector Agent (PydanticAI)
CONFLICT_DETECTOR_AGENT_ID=00000000-0000-0000-0000-000000000002
CONFLICT_DETECTOR_API_KEY=band_u_conflict-detector-key-here

# Weather Analyst Agent (CrewAI)
WEATHER_ANALYST_AGENT_ID=00000000-0000-0000-0000-000000000003
WEATHER_ANALYST_API_KEY=band_u_weather-analyst-key-here

# Ground Ops Agent (LangGraph)
GROUND_OPS_AGENT_ID=00000000-0000-0000-0000-000000000004
GROUND_OPS_API_KEY=band_u_ground-ops-key-here

# Emergency Response Agent (LangGraph)
EMERGENCY_RESPONSE_AGENT_ID=00000000-0000-0000-0000-000000000005
EMERGENCY_RESPONSE_API_KEY=band_u_emergency-response-key-here

# Safety Reviewer Agent (PydanticAI) — adversarial review before controller action
SAFETY_REVIEWER_AGENT_ID=00000000-0000-0000-0000-000000000006
SAFETY_REVIEWER_API_KEY=band_u_safety-reviewer-key-here

# ----------------------------------------------------------------------------
# OpenSky Network — https://opensky-network.org (optional, for live mode)
# ----------------------------------------------------------------------------
# Register at https://opensky-network.org, then enter your credentials.
# Without these, the system runs in simulation-only mode.
# OPENSKY_USERNAME=your-opensky-username
# OPENSKY_PASSWORD=your-opensky-password

# ----------------------------------------------------------------------------
# Frontend — Vite environment variables
# ----------------------------------------------------------------------------
# These are read at build time by Vite. Defaults work for local development.
# VITE_WS_URL=ws://localhost:8000/ws
# VITE_API_URL=http://localhost:8000
