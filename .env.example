# ATC Guardian Backend Configuration
# Copy this file to .env and fill in your values

# Application
DEBUG=false
DEFAULT_SCENARIO_ID=SCN-A
SIMULATION_INTERVAL_SECONDS=4.0
CORS_ORIGIN=http://localhost:5173

# OpenSky Network (optional — simulation-only mode if not set)
# OPATIONSKY_USERNAME=
# OPATIONSKY_PASSWORD=

# Band Platform (optional — agents-only mode if not set)
# BAND_API_KEY=
# BAND_ROOM_ID=

# AI/ML API (primary LLM provider for hackathon partner credits)
# AIMLAPI_KEY=

# Featherless AI (secondary LLM provider)
# FEATHERLESS_KEY=

# Coordinator Agent (Band credentials)
# COORDINATOR_AGENT_ID=
# COORDINATOR_API_KEY=

# Conflict Detector Agent (Band credentials)
# CONFLICT_DETECTOR_AGENT_ID=
# CONFLICT_DETECTOR_API_KEY=

# Weather Analyst Agent (Band credentials)
# WEATHER_ANALYST_AGENT_ID=
# WEATHER_ANALYST_API_KEY=

# Ground Ops Agent (Band credentials)
# GROUND_OPS_AGENT_ID=
# GROUND_OPS_API_KEY=

# Emergency Response Agent (Band credentials)
# EMERGENCY_RESPONSE_AGENT_ID=
# EMERGENCY_RESPONSE_API_KEY=
