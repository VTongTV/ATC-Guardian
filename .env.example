# ============================================================================
# ATC Guardian — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# Get keys from:
#   - OpenRouter:  https://openrouter.ai (free, no CC)
#   - Band:        https://app.band.ai/agents (6 remote agents)
#   - OpenSky:     https://opensky-network.org (free, optional)
#   - AI/ML API:   https://aimlapi.com (hackathon partner promo)
# ============================================================================

# --- Application ---
DEBUG=false
DEFAULT_SCENARIO_ID=SCN-A
SIMULATION_INTERVAL_SECONDS=4.0
CORS_ORIGIN=http://localhost:5173

# --- LLM Provider (openrouter | aimlapi) ---
LLM_PROVIDER=openrouter

# OpenRouter (free dev/testing)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=nex-agi/nex-n2-pro:free

# AI/ML API (hackathon partner — per-agent model routing in shared/partner_routing.py)
AIMLAPI_KEY=
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_DEFAULT_MODEL=deepseek/deepseek-v4-pro

# Per-Agent Model Overrides (optional — uncomment to override provider default)
# CONFLICT_DETECTOR_MODEL=deepseek/deepseek-v4-pro
# SAFETY_REVIEWER_MODEL=zhipu/glm-5.1
# WEATHER_ANALYST_MODEL=deepseek/deepseek-v4-pro
# COORDINATOR_MODEL=moonshot/kimi-k2-6
# EMERGENCY_RESPONSE_MODEL=zhipu/glm-5.1
# GROUND_OPS_MODEL=deepseek/deepseek-v4-flash

# --- Band Platform (sim mode default; live needs all 6 agent keys + room) ---
BAND_MODE=sim
BAND_API_KEY=band_u_your-band-api-key-here
BAND_ROOM_ID=00000000-0000-0000-0000-000000000000
COORDINATOR_AGENT_ID=00000000-0000-0000-0000-000000000001
COORDINATOR_API_KEY=band_u_coordinator-key-here
CONFLICT_DETECTOR_AGENT_ID=00000000-0000-0000-0000-000000000002
CONFLICT_DETECTOR_API_KEY=band_u_conflict-detector-key-here
WEATHER_ANALYST_AGENT_ID=00000000-0000-0000-0000-000000000003
WEATHER_ANALYST_API_KEY=band_u_weather-analyst-key-here
GROUND_OPS_AGENT_ID=00000000-0000-0000-0000-000000000004
GROUND_OPS_API_KEY=band_u_ground-ops-key-here
EMERGENCY_RESPONSE_AGENT_ID=00000000-0000-0000-0000-000000000005
EMERGENCY_RESPONSE_API_KEY=band_u_emergency-response-key-here
SAFETY_REVIEWER_AGENT_ID=00000000-0000-0000-0000-000000000006
SAFETY_REVIEWER_API_KEY=band_u_safety-reviewer-key-here

# --- OpenSky Network (optional, for live mode) ---
# OPENSKY_USERNAME=your-opensky-username
# OPENSKY_PASSWORD=your-opensky-password

# --- Frontend (Vite — defaults work locally) ---
# VITE_WS_URL=ws://localhost:8000/ws
# VITE_API_URL=http://localhost:8000
