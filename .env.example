# ATC Guardian Backend Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Application
# ============================================================================
DEBUG=false
DEFAULT_SCENARIO_ID=SCN-A
SIMULATION_INTERVAL_SECONDS=4.0
CORS_ORIGIN=http://localhost:5173

# ============================================================================
# LLM Provider Selection
# ============================================================================
# Active provider: openrouter | aimlapi | featherless
# - openrouter: Free models for development/testing (default)
# - aimlapi: Hackathon partner with credits (use for demo/judging)
# - featherless: Hackathon partner backup
LLM_PROVIDER=openrouter

# ============================================================================
# OpenRouter (free models — sign up at https://openrouter.ai)
# ============================================================================
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Free model options (all support tool calling):
#   meta-llama/llama-3.3-70b-instruct:free     — general-purpose, 128K
#   nvidia/nemotron-3-ultra-550b-a55b:free      — reasoning, 1M context
#   qwen/qwen3-coder:free                       — coding, 1M context
#   openai/gpt-oss-120b:free                    — OpenAI open-weight, 128K
#   openai/gpt-oss-20b:free                      — lightweight, 128K
#   google/gemma-4-31b-it:free                   — multimodal, 256K
#   openrouter/free                               — auto-selects best free model
# Rate limits: 20 RPM / 200 RPD per model on free tier

# ============================================================================
# AI/ML API (hackathon partner — use for demo/judging)
# ============================================================================
AIMLAPI_KEY=
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_DEFAULT_MODEL=gpt-4o

# ============================================================================
# Featherless (hackathon partner — secondary)
# ============================================================================
FEATHERLESS_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1

# ============================================================================
# Per-Agent Model Overrides (optional — falls back to provider default)
# ============================================================================
# Uncomment and set to override the model for a specific agent:
# COORDINATOR_MODEL=meta-llama/llama-3.3-70b-instruct:free
# CONFLICT_DETECTOR_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
# WEATHER_ANALYST_MODEL=meta-llama/llama-3.3-70b-instruct:free
# GROUND_OPS_MODEL=meta-llama/llama-3.3-70b-instruct:free
# EMERGENCY_RESPONSE_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# ============================================================================
# OpenSky Network (optional — simulation-only mode if not set)
# ============================================================================
# OPATIONSKY_USERNAME=
# OPATIONSKY_PASSWORD=

# ============================================================================
# Band Platform (optional — agents-only mode if not set)
# ============================================================================
# BAND_API_KEY=
# BAND_ROOM_ID=

# ============================================================================
# Agent Band Credentials (register agents at band.ai)
# ============================================================================
# Coordinator Agent
# COORDINATOR_AGENT_ID=
# COORDINATOR_API_KEY=

# Conflict Detector Agent
# CONFLICT_DETECTOR_AGENT_ID=
# CONFLICT_DETECTOR_API_KEY=

# Weather Analyst Agent
# WEATHER_ANALYST_AGENT_ID=
# WEATHER_ANALYST_API_KEY=

# Ground Ops Agent
# GROUND_OPS_AGENT_ID=
# GROUND_OPS_API_KEY=

# Emergency Response Agent
# EMERGENCY_RESPONSE_AGENT_ID=
# EMERGENCY_RESPONSE_API_KEY=
