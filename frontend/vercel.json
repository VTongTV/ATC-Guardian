{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/data/:path*", "destination": "https://atc-guardian-backend.onrender.com/data/:path*" },
    { "source": "/audit/:path*", "destination": "https://atc-guardian-backend.onrender.com/audit/:path*" },
    { "source": "/weather/:path*", "destination": "https://atc-guardian-backend.onrender.com/weather/:path*" },
    { "source": "/decisions/:path*", "destination": "https://atc-guardian-backend.onrender.com/decisions/:path*" },
    { "source": "/collaboration/:path*", "destination": "https://atc-guardian-backend.onrender.com/collaboration/:path*" },
    { "source": "/whatif/:path*", "destination": "https://atc-guardian-backend.onrender.com/whatif/:path*" },
    { "source": "/ws/:path*", "destination": "https://atc-guardian-backend.onrender.com/ws/:path*" }
  ]
}
